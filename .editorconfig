root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{cs,xaml}]
indent_style = space
indent_size = 4

[*.{json,yml,yaml,xml,props,targets,csproj,sln}]
indent_style = space
indent_size = 2
