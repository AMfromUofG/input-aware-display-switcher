<Window x:Class="InputAwareDisplaySwitcher.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewModels="clr-namespace:InputAwareDisplaySwitcher.App.ViewModels"
        xmlns:views="clr-namespace:InputAwareDisplaySwitcher.App.Views"
        Title="{Binding WindowTitle}"
        Width="1280"
        Height="800"
        MinWidth="1080"
        MinHeight="720"
        Background="#FFF5F6F8">
  <Window.Resources>
    <DataTemplate DataType="{x:Type viewModels:DevicesViewModel}">
      <views:DevicesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:ZonesProfilesViewModel}">
      <views:ZonesProfilesView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:RulesSettingsViewModel}">
      <views:RulesSettingsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:DiagnosticsViewModel}">
      <views:DiagnosticsView />
    </DataTemplate>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="260" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="#FF1F2937"
            Padding="20">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,28">
          <TextBlock Foreground="White"
                     FontSize="24"
                     FontWeight="SemiBold"
                     Text="Input Aware Display Switcher" />
          <TextBlock Margin="0,8,0,0"
                     Foreground="#FFD1D5DB"
                     TextWrapping="Wrap"
                     Text="Application shell for configuration, rules, and diagnostics." />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Margin="0,0,0,12"
                   Foreground="#FF9CA3AF"
                   FontSize="12"
                   Text="Sections" />

        <ListBox Grid.Row="2"
                 ItemsSource="{Binding NavigationItems}"
                 SelectedItem="{Binding SelectedNavigation, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Margin" Value="0,0,0,8" />
              <Setter Property="Padding" Value="12" />
              <Setter Property="Foreground" Value="White" />
              <Setter Property="Background" Value="#332D3748" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="BorderThickness" Value="0" />
              <Style.Triggers>
                <Trigger Property="IsSelected"
                         Value="True">
                  <Setter Property="Background" Value="#FF3B82F6" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <StackPanel>
                <TextBlock FontSize="15"
                           FontWeight="SemiBold"
                           Text="{Binding Title}" />
                <TextBlock Margin="0,4,0,0"
                           Foreground="#FFE5E7EB"
                           TextWrapping="Wrap"
                           Text="{Binding Summary}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Grid Grid.Column="1"
          Margin="24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border Grid.Row="0"
              Background="White"
              CornerRadius="12"
              Padding="20"
              Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Grid.Column="0">
            <TextBlock FontSize="28"
                       FontWeight="SemiBold"
                       Text="{Binding CurrentSection.Title}" />
            <TextBlock Margin="0,8,0,0"
                       Foreground="#FF4B5563"
                       TextWrapping="Wrap"
                       Text="{Binding CurrentSection.Description}" />
          </StackPanel>

          <StackPanel Grid.Column="1"
                      HorizontalAlignment="Right">
            <TextBlock FontSize="12"
                       Foreground="#FF6B7280"
                       Text="Config file" />
            <TextBlock Margin="0,4,0,0"
                       FontFamily="Consolas"
                       Text="{Binding ConfigurationPath}" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1"
              Background="White"
              CornerRadius="12"
              Padding="20">
        <ContentControl Content="{Binding CurrentSection}" />
      </Border>
    </Grid>
  </Grid>
</Window>
